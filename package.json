    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cloudinary": "^2.9.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "firebase-admin": "^13.6.1",
    "joi": "^18.0.2",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.2",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "satori": "^0.19.2",
    "satori-html": "^0.3.2",
    "simple-slugify": "^1.0.0",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1"
